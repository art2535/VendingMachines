<Page x:Class="VendingMachines.Desktop.Account.Pages.AddVendingMachinePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:VendingMachines.Desktop.Account.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="800"
      Loaded="Page_Loaded"
      Title="AddVendingMachinePage">
    
    <Page.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="19"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="FontSize" Value="11"/>
        </Style>
    </Page.Resources>

    <Grid Margin="100 0" Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="0.1*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="0.1*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Создание торгового автомата" 
                   Grid.Row="0" Foreground="Blue"
                   FontSize="18" Margin="10 5"
                   TextAlignment="Left"
                   x:Name="InfoTextBlock"/>

        <StackPanel Orientation="Vertical" Grid.Row="1" Margin="20">
            <StackPanel Orientation="Horizontal" Margin="0 10">
                <StackPanel Width="160" Margin="0">
                    <TextBlock Text="Производитель (Компания) *"/>
                    <ComboBox x:Name="MachineManufacturerComboBox"/>
                </StackPanel>
                <StackPanel Width="160" Margin="20 0">
                    <TextBlock Text="Модель *"/>
                    <ComboBox x:Name="ModelComboBox"/>
                </StackPanel>
                <StackPanel Width="160" Margin="20 0">
                    <TextBlock Text="Модем *"/>
                    <ComboBox x:Name="ModemComboBox"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0 10">
                <StackPanel Width="160" Margin="5 0">
                    <TextBlock Text="Адрес *"/>
                    <TextBox x:Name="AddressTextBox"/>
                </StackPanel>
                <StackPanel Width="160" Margin="20 0">
                    <TextBlock Text="Место *"/>
                    <TextBox x:Name="PlaceTextBox"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="2"
                    Margin="10 0">
            <Button x:Name="ButtonCreateMachine"
                    Content="Создать" Background="Blue"
                    Foreground="White"
                    Width="100" Height="25"
                    Click="ButtonCreateMachine_Click"/>
            <Button x:Name="ButtonCancel"
                    Content="Отменить" Margin="10 0"
                    Foreground="Black" Background="White"
                    Width="100" Height="25"
                    Click="ButtonCancel_Click"/>
        </StackPanel>
    </Grid>
</Page>
